# Build outputs
/build/bin/
*.app/
*.dmg

# Standalone `go build` output (the module name produces a "ytdisc"
# binary at the repo root). Real builds go in build/bin/ via wails.
/ytdisc

# Wails-generated bindings (regenerated on every wails dev/build)
/frontend/wailsjs/

# Frontend build output (regenerated by frontend/build.js)
/frontend/dist/

# Node
node_modules/

# macOS
.DS_Store
._*

# Windows
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp

# Runtime library — never check the user's media into the repo
/Videos/

# Position-state file (created at runtime next to Videos/)
.state.json
.state.json.tmp
